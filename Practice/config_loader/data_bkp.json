{
    "defaults": {
        "debug": false,
        "log_level": "INFO",
        "max_connections": 10,
        "timeout": 30,
        "retry_count": 3,
        "app_name": "MyApp"
    },
    "development": {
        "debug": true,
        "log_level": "DEBUG",
        "db_host": "localhost",
        "db_port": 5432,
        "db_name": "myapp_dev",
        "db_user": "dev_user",
        "db_password": "dev_pass"
    },
    "staging": {
        "log_level": "WARNING",
        "db_host": "staging.db.example.com",
        "db_port": 5432,
        "db_name": "myapp_staging",
        "db_user": "staging_user",
        "db_password": "staging_pass",
        "max_connections": 20
    },
    "production": {
        "debug": false,
        "log_level": "ERROR",
        "db_host": "prod.db.example.com",
        "db_port": 5432,
        "db_name": "myapp_prod",
        "db_user": "prod_user",
        "db_password": "prod_pass",
        "max_connections": 100,
        "timeout": 60
    }
}